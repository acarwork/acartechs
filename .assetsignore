# Cloudflare Workers static assets — do not upload build/source/git internals.
# Without this, CI clones include .git pack files that can exceed the 25 MiB
# per-asset limit and fail deploy with "Asset too large".

.git
.wrangler
node_modules

# Worker source and config (not public site files)
src
functions
wrangler.jsonc
wrangler.toml
package.json
package-lock.json
pnpm-lock.yaml
yarn.lock

# Misc
.DS_Store
.env
.env.*
*.md
.gitignore
.assetsignore
